# CYD Voice — secrets.yaml
# Copy this file to secrets.yaml and fill in your values.

# Primary WiFi network
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Secondary WiFi (optional, e.g., phone hotspot for testing)
wifi_ssid_2: "YourBackupSSID"
wifi_password_2: "YourBackupPassword"

# API encryption key (generate with: openssl rand -base64 32)
api_encryption_key: "GENERATE_A_RANDOM_KEY_HERE"

# OTA update password
ota_password: "your-ota-password"
